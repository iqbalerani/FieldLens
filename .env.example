AWS_REGION=us-east-1
NOVA_LITE_MODEL_ID=amazon.nova-lite-v2:0
NOVA_SONIC_MODEL_ID=amazon.nova-sonic-v2:0
NOVA_EMBED_MODEL_ID=amazon.nova-embed-multimodal-v1:0
DATABASE_URL=sqlite+aiosqlite:///./fieldlens.db
# For production: postgresql+asyncpg://user:password@host:5432/fieldlens
S3_BUCKET_NAME=fieldlens-media-dev
AUTH_MODE=demo
# AUTH_MODE=cognito for production with AWS Cognito
AI_MODE=mock
# AI_MODE=bedrock for production with real Amazon Nova models
STORAGE_MODE=local
# STORAGE_MODE=s3 for production with Amazon S3
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000
EXPO_PUBLIC_AUTH_MODE=demo
SNS_TOPIC_ARN=
# Set to your SNS topic ARN to enable critical-issue supervisor notifications
# e.g. arn:aws:sns:us-east-1:123456789012:fieldlens-critical-alerts
GUNICORN_WORKERS=4

